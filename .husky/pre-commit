#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "Linting staged TypeScript files..."

# Get staged .ts/.tsx files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo "No staged TS/TSX files to lint"
  exit 0
fi

# Run ESLint
npx eslint $STAGED_FILES --max-warnings=0 --no-warn-ignored
RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo "❌ Lint failed — commit aborted"
  exit 1
fi

echo "✅ Lint passed — committing"
