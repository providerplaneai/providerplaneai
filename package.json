{
    "type": "module",
    "name": "providerplaneai",
    "version": "0.2.0",
    "description": "Multi-provider AI abstraction layer for Node.js applications.",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "license": "MIT",
    "scripts": {
        "prepare": "husky install",
        "clean": "rimraf dist",
        "playground": "node dist/playground.js",
        "build": "npm run clean && tsc -p tsconfig.build.json",
        "dev": "nodemon --watch src --ext ts --exec \"npm run build && npm run playground\"",
        "lint": "eslint . --ext .ts,.tsx --no-warn-ignored",
        "lint:fix": "eslint . --ext .ts,.tsx --fix",
        "test": "vitest run --coverage",
        "test:watch": "vitest"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/providerplaneai/providerplaneai.git"
    },
    "bugs": {
        "url": "https://github.com/providerplaneai/providerplaneai/issues"
    },
    "homepage": "https://github.com/providerplaneai/providerplaneai#readme",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "imports": {
        "#root/*": "./dist/*"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@anthropic-ai/sdk": "^0.68.0",
        "@google/genai": "^1.34.0",
        "@huggingface/inference": "^4.13.2",
        "commander": "^14.0.2",
        "config": "^4.1.1",
        "dotenv": "^17.2.3",
        "openai": "^6.9.0",
        "sharp": "^0.34.5",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.3",
        "@types/config": "^3.3.5",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^8.53.1",
        "@typescript-eslint/parser": "^8.53.1",
        "@vitest/coverage-istanbul": "^4.0.8",
        "baseline-browser-mapping": "^2.9.17",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^8.0.0",
        "nodemon": "^3.1.10",
        "prettier": "^3.8.1",
        "rimraf": "^6.1.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.8"
    }
}
